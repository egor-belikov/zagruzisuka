APPLICATION_NAME=yt_worker

# yt-dlp через Mihomo (см. proxy/mihomo.yaml); без этого Instagram/Meta с российского IP часто падают.
YTDLP_PROXY=socks5h://yt_proxy:10808

MAX_SIMULTANEOUS_DOWNLOADS=2
MAX_DOWNLOAD_THREADS=10
# Лимит одного видео по умолчанию 1 GiB (см. downloader _DEFAULT_MAX_FILESIZE). Без лимита: YTDLP_MAX_FILESIZE_BYTES=0
# Длинные ролики (порог сек): YTDLP_LONG_VIDEO_SECONDS=600 (0 = выкл). Свой format: YTDLP_LONG_VIDEO_FORMAT

STORAGE_PATH=/filestorage

THUMBNAIL_FRAME_SECOND=10.0
INSTAGRAM_ENCODE_TO_H264=True
FACEBOOK_ENCODE_TO_H264=True
